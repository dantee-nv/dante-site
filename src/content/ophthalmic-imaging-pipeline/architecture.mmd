  dagster --> valid["AWS S3<br/>validated/&lt;image_id&gt;/"]
  dagster --> quarantine["AWS S3<br/>quarantine/&lt;image_id&gt;/"]
  valid --> lakefs["lakeFS<br/>ingestion-run-001 branch<br/>commit + v1.0 tag"]
  lakefs --> tasks["Label Studio Tasks<br/>image quality + class review"]
  tasks --> annotations["Annotation Export Import<br/>supported labels + image_id checks"]
  annotations --> split["Fixed-Seed Split<br/>80% training / 20% validation"]
  split --> manifest["Dataset Release<br/>CSV files + manifest + validation report"]

